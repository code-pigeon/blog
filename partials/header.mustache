        <img src="https://weavatar.com/avatar/3e8c711042f5b5a31a46c488f6b3c558" alt="个人头像" class="avatar">
        <span class="nickname">{{{blog_name}}}</span>
    </div>
    
    <!-- 右侧导航菜单（保持原有结构） -->
	<nav>
        <!-- 汉堡菜单按钮 -->
        <div class="hamburger" id="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </div>

	    <ul id="nav-menu">
	    	{{#nav}}
	    		<li><a href="{{url}}">{{{label}}}</a></li>
	    	{{/nav}}
	    </ul>
	</nav>
</header>