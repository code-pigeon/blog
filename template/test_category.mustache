<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>分类</title>
    <link href="../{{css_url}}index.css" rel="stylesheet">
    <link href="../{{css_url}}category.css" rel="stylesheet">
    <!-- syntax highlighting -->
    <link rel="stylesheet" type="text/css" href="../{{css_url}}code_highlight.css">
    <link rel="stylesheet" type="text/css" href="../{{css_url}}date_and_updated.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <!-- table of content -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.27.4/tocbot.min.js"></script>
    
</head>
<body>
    {{> header}}
    <div class=fluid> 
        <h1 class="h1">分类</h1>
        <div class="categories-container">
            {{#category}}

            <!-- 示例数据结构 - 您可以根据实际数据结构调整 -->
            {{#category}}
            <div class="main-category-section">
                <h2 class="main-category">{{name}}</h2>
                {{#posts.0}}
                <ul class="post-list">
                {{/posts.0}}
                    {{#posts}}
                    <li class="post-item">
                        <div class="post-content">
                            <span class="post-date">{{date}}</span>
                            <a href="{{quote_html_filename}}" class="post-title">{{title}}</a>
                            {{#tags.0}}
                            <div class="post-tags">
                            {{/tags.0}}
                                {{#tags}}
                                <span class="post-tag">{{.}}</span>
                                {{/tags}}
                            {{#tags.0}}
                            </div>
                            {{/tags.0}}
                        </div>
                    </li>
                    {{/posts}}
                {{#posts.0}}
                </ul>
                {{/posts.0}}


                {{#subcategory}}
                <div class="sub-category-section">
                    <h3 class="sub-category">{{name}}</h3>
                    
                    {{#posts.0}}
                    <ul class="post-list">
                    {{/posts.0}}
                        {{#posts}}
                        <li class="post-item">
                            <div class="post-content">
                                <span class="post-date">{{date}}</span>
                                <a href="{{quote_html_filename}}" class="post-title">{{title}}</a>
                                {{#tags.0}}
                                <div class="post-tags">
                                {{/tags.0}}
                                    {{#tags}}
                                    <span class="post-tag">{{.}}</span>
                                    {{/tags}}
                                {{#tags.0}}
                                </div>
                                {{/tags.0}}
                            </div>
                        </li>
                        {{/posts}}
                    {{#posts.0}}
                    </ul>
                    {{/posts.0}}
                    
                    
                    <!-- {^posts}
                    <p class="empty-category">此分类下暂无文章</p>
                    {/posts} -->
                </div>
                {{/subcategory}}
            </div>
            {{/category}}
            {{/category}}
        </div>
    </div>
    <div class="left-sidebar">
            <div class="toc"></div>
            <div class="toc-toggle"></div>
        </div>
    <script src="../{{js_url}}code_highlight.js" type="text/javascript"></script>
    <script src="../{{js_url}}toc.js" type="text/javascript" ></script>
    <script src="../{{js_url}}image.js" type="text/javascript"></script>
</body>
</html>