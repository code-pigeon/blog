<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>分类</title>
    <link href="{{css_url}}index.css" rel="stylesheet">
    <link href="{{css_url}}category.css" rel="stylesheet">
    <!-- hamburger -->
    <link rel="stylesheet" type="text/css" href="{{css_url}}hamburger.css">
    <script src="{{js_url}}hamburger.js" type="text/javascript"></script>
    <!-- goatcounter -->
    <script data-goatcounter="https://code-pigeon.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.27.4/tocbot.min.js"></script>
</head>
<body>
    <!-- 头部 -->
    {{>header}}

    <!-- 主要内容区域 -->
    <div class="fluid">
        <h1 id="分类">分类</h1>
        <div class="categories-container">
            {{#category}}

            <!-- 示例数据结构 - 您可以根据实际数据结构调整 -->
            {{#category}}
            <div class="main-category-section">
                <h2 class="main-category">{{name}}</h2>
                {{#posts.0}}
                <ul class="post-list">
                {{/posts.0}}
                    {{#posts}}
                    <li class="post-item">
                        <div class="post-content">
                            <span class="post-date">{{date}}</span>
                            <a href="{{quote_html_filename}}" class="post-title">{{title}}</a>
                            {{#tags.0}}
                            <div class="post-tags">
                            {{/tags.0}}
                                {{#tags}}
                                <span class="post-tag">{{.}}</span>
                                {{/tags}}
                            {{#tags.0}}
                            </div>
                            {{/tags.0}}
                        </div>
                    </li>
                    {{/posts}}
                {{#posts.0}}
                </ul>
                {{/posts.0}}


                {{#subcategory}}
                <div class="sub-category-section">
                    <h3 class="sub-category">{{name}}</h3>
                    
                    {{#posts.0}}
                    <ul class="post-list">
                    {{/posts.0}}
                        {{#posts}}
                        <li class="post-item">
                            <div class="post-content">
                                <span class="post-date">{{date}}</span>
                                <a href="{{quote_html_filename}}" class="post-title">{{title}}</a>
                                {{#tags.0}}
                                <div class="post-tags">
                                {{/tags.0}}
                                    {{#tags}}
                                    <span class="post-tag">{{.}}</span>
                                    {{/tags}}
                                {{#tags.0}}
                                </div>
                                {{/tags.0}}
                            </div>
                        </li>
                        {{/posts}}
                    {{#posts.0}}
                    </ul>
                    {{/posts.0}}
                    
                    
                    <!-- {^posts}
                    <p class="empty-category">此分类下暂无文章</p>
                    {/posts} -->
                </div>
                {{/subcategory}}
            </div>
            {{/category}}
            {{/category}}
        </div>
        
