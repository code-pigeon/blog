<!DOCTYPE html>
<html>
<head>
	{{>common_head}}
	<title>{{{title}}}</title>
	<!-- syntax highlighting -->
	<link rel="stylesheet" type="text/css" href="{{css_url}}code_highlight.css">
	<link rel="stylesheet" type="text/css" href="{{css_url}}date_and_updated.css">
	<!-- code highlight -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
</head>
<body>
	{{> header}}
	<div class=fluid> 
		{{#auto_h1}}
		<h1 id="{{{title}}}">{{{title}}}</h1>
		{{/auto_h1}}
		<div class="article-meta">
			{{#date}}
			<div class="meta-item">
				<svg class="meta-icon" viewBox="0 0 24 24">
				<path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/>
				</svg>
				<span class="meta-label">创建</span>
				<time class="meta-time">{{{date}}}</time>
			</div>
			{{/date}}
			{{#updated}}
			<div class="meta-item">
				<svg class="meta-icon" viewBox="0 0 24 24">
				<path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
				</svg>
				<span class="meta-label">更新</span>
				<time class="meta-time">{{{updated}}}</time>
			</div>
			{{/updated}}
			{{#category}}
			<div class="meta-item">
				<span class="meta-label">{{.}}</span>
			</div>
			{{/category}}
		</div>


{{> content }}

		<br />
		<hr />

		<!-- visitor -->
		<!-- id 将作为查询条件 -->
		<span id="/blog/{{html_dir}}{{{ quote_html_filename }}}" class="leancloud_visitors" data-flag-title="{{{title}}}">
		    <em class="post-meta-item-text">阅读量 </em>
		    <i class="leancloud-visitors-count">0</i>
		</span>
		<!-- \visitor -->

		<br />

		{{#has_comment}}
		<h2 id="评论">评论</h2>
		<!-- <div class="giscus"></div> -->
		<div id="vcomments"></div>
		{{/has_comment}}
	</div>



	<!-- /////////////////////////////////////////////////////////////////////////////////////////////////////////// -->

	<!-- /////////////// script region //////////////// -->

	{{>common_foot}}

	<script src="{{js_url}}code_highlight.js" type="text/javascript"></script>
		



</body>
</html>